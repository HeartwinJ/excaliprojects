# ---------- App ----------
APP_PORT=3000
# Image tag to pull from GHCR in production (e.g. latest, 1.2.3, sha-abc1234).
# See https://github.com/HeartwinJ/excaliprojects/pkgs/container/excaliprojects for tags.
IMAGE_TAG=latest
# The origin users reach the app from, externally (scheme + host + optional port).
# Used to build absolute share-link URLs and set cookie domain/Secure flags.
PUBLIC_APP_URL=https://draw.example.com
NODE_ENV=production

# ---------- Seed user (created on first boot if no user exists) ----------
SEED_USERNAME=changeme
SEED_PASSWORD=changeme-to-something-long

# ---------- Auth ----------
# Long random string used to cryptographically sign session cookies so they
# can't be forged. Never commit the real value. Rotating it logs everyone out.
# Generate with:  openssl rand -base64 48
SESSION_SECRET=generate-a-long-random-string
SESSION_MAX_AGE_DAYS=30

# ---------- Postgres ----------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=excaliprojects
POSTGRES_USER=excaliprojects
POSTGRES_PASSWORD=change-this-postgres-password

# ---------- File storage ----------
FILES_DIR=/data/files
MAX_UPLOAD_MB=25

# ---------- Autosave / versioning ----------
AUTOSAVE_DEBOUNCE_MS=1500
AUTOSNAPSHOT_EVERY_N_SAVES=10
MAX_AUTOSNAPSHOTS_PER_BOARD=20

# ---------- Share links ----------
SHARE_LINKS_ENABLED=true
